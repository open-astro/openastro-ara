# Environment overrides for the OpenAstro Ara server.
# Rename this file to /etc/openastroara/server.env (no .example) to apply.
# All values are optional; defaults are documented next to each line.

# Kestrel listen port. Resolution order per OpenAstroAra.Server/Program.cs ResolvePort:
#   1. OPENASTROARA_PORT env (this file)
#   2. OpenAstroAra:Port in appsettings.json
#   3. Default 5555
#OPENASTROARA_PORT=5555

# .NET tracing / logging verbosity overrides — uncomment if you need
# verbose Serilog output for troubleshooting per §29.9.
#Serilog__MinimumLevel__Default=Debug
