platform :osx, '10.15'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure \"flutter pub get\" is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run \"flutter pub get\""
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)
  end

  # §36 webview_cef: the vendored CEF binary is named "Chromium Embedded
  # Framework.framework" (spaces in the name). CocoaPods mis-tokenizes that
  # into OTHER_LDFLAGS as `Embedded Framework -framework "Chromium"`, so clang
  # sees bare `Embedded`/`Framework` input files and the link fails. Rewrite the
  # generated Pods-Runner xcconfigs to the correctly-quoted single flag. This
  # runs after CocoaPods writes the files, and re-runs on every `pod install`.
  broken = 'Embedded Framework -framework "Chromium"'
  correct = '-framework "Chromium Embedded Framework"'
  support_dir = File.join(installer.sandbox.root, 'Target Support Files', 'Pods-Runner')
  xcconfigs = Dir.glob(File.join(support_dir, 'Pods-Runner.*.xcconfig'))
  applied = 0
  already_ok = 0
  xcconfigs.each do |xcconfig|
    contents = File.read(xcconfig)
    if contents.include?(broken)
      File.write(xcconfig, contents.gsub(broken, correct))
      applied += 1
    elsif contents.include?(correct)
      already_ok += 1
    end
  end
  # Fail loudly if the fix matched nothing: a future CocoaPods version may tokenize
  # the space-containing framework name differently, in which case the link breaks
  # with a cryptic clang error and no hint that this hook silently no-op'd.
  if applied.zero? && already_ok.zero? && !xcconfigs.empty?
    warn "WARNING: §36 webview_cef CEF link-flag fix matched nothing in " \
         "#{xcconfigs.length} Pods-Runner xcconfig(s). CocoaPods may have changed " \
         "its OTHER_LDFLAGS tokenization — the macOS build will likely fail to link " \
         "\"Chromium Embedded Framework\". Update the post_install hook in macos/Podfile."
  end
end
