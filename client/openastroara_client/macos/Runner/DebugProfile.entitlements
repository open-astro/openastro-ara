<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Sandbox is OFF: this is a Developer-ID-distributed desktop control app
	     (not Mac App Store) that needs unrestricted local LAN + equipment access
	     (the daemon connection, mDNS discovery, the loopback planetarium asset
	     server) and local file access. Re-enabling the sandbox is a possible future
	     tightening now that CEF — which required it off for its Mach rendezvous — is
	     gone; that needs on-device verification of LAN/mDNS/file access first. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<!-- LAN: connect to the daemon (client) + mDNS discovery / loopback asset
	     server (server). files.user-selected for §54 log/bug-report export. -->
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
</dict>
</plist>
